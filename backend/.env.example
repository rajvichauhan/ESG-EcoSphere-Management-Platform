# Copy to .env and fill in. NEVER commit real credentials.

# --- App ---
APP_NAME=EcoSphere
APP_ENV=development
API_PREFIX=/api

# --- MongoDB ---
# Transactions (used from Phase 8 onward) require a replica set.
# In dev: `mongod --replSet rs0` then once: mongosh --eval "rs.initiate()"
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGODB_DB=ecosphere

# --- Auth (Phase 2) ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30

# --- Email / Gmail SMTP (Phase 2) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_APP_PASSWORD=your-16-char-app-password
SMTP_FROM=EcoSphere <your-address@gmail.com>

# --- File storage ---
# backend = local | b2   (swap the storage layer only; no other code changes)
FILE_STORAGE_BACKEND=local
FILE_STORAGE_LOCAL_DIR=./uploads
# B2_KEY_ID=
# B2_APP_KEY=
# B2_BUCKET=
# B2_ENDPOINT=
