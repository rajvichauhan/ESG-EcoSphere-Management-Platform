# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/veridian_esg?replicaSet=rs0

# Security & Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# SMTP Configuration (Notifications & Verification Codes)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_APP_PASSWORD=your_secure_smtp_app_password

# File Storage Configuration (local | b2)
FILE_STORAGE_BACKEND=local
FILE_STORAGE_LOCAL_DIR=./uploads

# Backblaze B2 Credentials (Optional - Phase 2 Cloud Storage)
# B2_KEY_ID=your_b2_key_id
# B2_APP_KEY=your_b2_app_key
# B2_BUCKET=your_b2_bucket_name
