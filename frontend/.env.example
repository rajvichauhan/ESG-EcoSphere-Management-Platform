# Copy to .env.local for local development.

# Base URL of the EcoSphere backend API. Defaults to "/api" (same-origin via a
# dev proxy). Point this at the FastAPI server, e.g. http://localhost:8000/api
VITE_API_BASE_URL=/api

# Offline/demo mode. When "true", the app serves local mock data ONLY when the
# backend is unreachable, and exposes the demo role-switcher. Leave OFF (unset or
# "false") for any real deployment so the app talks solely to the backend and
# surfaces the backend's real responses (validation, permissions, not-found).
VITE_USE_MOCKS=false
